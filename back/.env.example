PORT=4000
HOST=0.0.0.0

# Папка для журналов действий (адмиский аудит + системные логи).
# По умолчанию — соседняя папка ../logs.
LOGS_DIR=../logs

# Сколько дней хранить логи. Файлы старше — удаляются автоматически.
LOG_RETENTION_DAYS=30

# CORS — фронт админки (vite).
CORS_ORIGIN=http://localhost:3000

# Имя текущего админа (пока нет авторизации — будем подставлять руками).
DEFAULT_ADMIN_NAME=Админ Ислам

# === База данных (пока не подключена) ===
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=poputka
# DB_USER=postgres
# DB_PASSWORD=
